{
  "name": "react-thermal-printer-sources",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "check": "biome check",
    "check:fix": "pnpm check --unsafe --write",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --incremental",
    "attw": "pnpm -r --filter './packages/*' run attw",
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "5.9.2",
    "vitest": "4.1.8"
  }
}
